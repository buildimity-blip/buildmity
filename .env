# MTN Configuration
MTN_API_URL=https://sandbox.mtn.com/api/
MTN_API_KEY=your_mtn_api_key_here
MTN_API_SECRET=your_mtn_api_secret_here
MTN_CALLBACK_URL=https://yourdomain.com/api/mtn-callback/
MTN_ENVIRONMENT=sandbox

# Airtel Configuration
AIRTEL_API_URL=https://openapi.airtel.africa/
AIRTEL_CLIENT_ID=your_airtel_client_id_here
AIRTEL_CLIENT_SECRET=your_airtel_client_secret_here
AIRTEL_CALLBACK_URL=https://yourdomain.com/api/airtel-callback/
AIRTEL_ENVIRONMENT=sandbox

# Django Secret Key
DJANGO_SECRET_KEY=your_secret_key_here

# IP Whitelisting for Payment Gateways
MTN_ALLOWED_IPS=52.20.112.96,54.221.171.118,34.228.210.72
AIRTEL_ALLOWED_IPS=52.20.112.96,54.221.171.118
CALLBACK_ALLOWED_IPS=52.20.112.96,54.221.171.118,34.228.210.72

# Your server IPs (add your actual server IPs)
YOUR_SERVER_IPS=127.0.0.1,localhost,your_actual_server_ip
